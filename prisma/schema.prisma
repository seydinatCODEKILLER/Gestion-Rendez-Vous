

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Specialite {
  GENERALISTE
  CARDIOLOGUE
  DENTISTE
  PEDIATRE
  DERMATOLOGUE
}

enum StatutRendezVous {
  PLANIFIE
  ANNULE
  TERMINE
  ABSENT
}

model Medecin {
  id          String          @id @default(cuid())
  matricule   String          @unique @db.VarChar(20)
  prenom      String          @db.VarChar(100)
  nom         String          @db.VarChar(100)
  specialite  Specialite
  telephone   String          @db.VarChar(20)
  email       String          @unique @db.VarChar(150)
  photo       String?         @db.Text
  actif       Boolean         @default(true)
  serviceId   String
  service     Service         @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  rendezVous  RendezVous[]
  @@index([nom, prenom])
  @@map("medecins")
}

model Patient {
  id            String       @id @default(cuid())
  matricule     String       @unique @db.VarChar(20)
  prenom        String       @db.VarChar(100)
  nom           String       @db.VarChar(100)
  dateNaissance DateTime     @map("date_naissance")
  telephone     String       @db.VarChar(20)
  adresse       String       @db.VarChar(255)
  photo         String?      @db.Text
  actif         Boolean      @default(true) 
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  rendezVous    RendezVous[]
  @@index([nom, prenom])
  @@map("patients")
}

model RendezVous {
  id          String             @id @default(cuid())
  date        DateTime           @map("date")
  heure       String             @map("heure")
  statut      StatutRendezVous   @default(PLANIFIE)
  medecinId   String             @map("medecin_id")
  patientId   String             @map("patient_id")
  medecin     Medecin  @relation(fields: [medecinId], references: [id], onDelete: Restrict)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  ordonnance  Ordonnance?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([medecinId, date, heure, statut])
  @@index([medecinId, date])
  @@index([patientId, date])
  @@map("rendez_vous")
}

model Ordonnance {
  id            String       @id @default(cuid())
  dateCreation  DateTime     @default(now()) @map("date_creation")
  description   String       @db.Text
  rendezVousId  String       @unique @map("rendez_vous_id")
  rendezVous    RendezVous   @relation(fields: [rendezVousId], references: [id], onDelete: Restrict)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@map("ordonnances")
}

model Service {
  id          String   @id @default(cuid())
  code        String   @db.VarChar(10)
  libelle     String   @db.VarChar(100)
  sousService String?  @db.VarChar(100)
  medecins    Medecin[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code, sousService])
  @@map("services")
}